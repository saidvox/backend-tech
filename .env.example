POSTGRES_DB=techstore
POSTGRES_USER=techstore
POSTGRES_PASSWORD=techstore123
POSTGRES_PORT=5432

DB_URL=jdbc:postgresql://localhost:5432/techstore
DB_USERNAME=techstore
DB_PASSWORD=techstore123
APP_DATASOURCE_AUTO_DETECT=true

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH2_SUCCESS_REDIRECT_URI=http://localhost:4200/auth/oauth2/success
OAUTH2_FAILURE_REDIRECT_URI=http://localhost:4200/login

MERCADO_PAGO_MODE=simulation
MERCADO_PAGO_API_BASE_URL=https://api.mercadopago.com
MERCADO_PAGO_SIMULATED_CHECKOUT_URL=http://localhost:4200/checkout/mercado-pago/simulacion
MERCADO_PAGO_NOTIFICATION_URL=http://localhost:8080/pagos/webhooks/mercado-pago
MERCADO_PAGO_SUCCESS_URL=http://localhost:4200/checkout/mercado-pago/retorno
MERCADO_PAGO_FAILURE_URL=http://localhost:4200/checkout/mercado-pago/retorno
MERCADO_PAGO_PENDING_URL=http://localhost:4200/checkout/mercado-pago/retorno
# Usa MERCADO_PAGO_MODE=simulation para demos locales sin cobros reales.
# Usa MERCADO_PAGO_MODE=sandbox solo cuando quieras probar el checkout externo de Mercado Pago.
# Para sandbox copia las credenciales desde "Credenciales de prueba".
# Mercado Pago puede mostrar estas credenciales con prefijo APP_USR- segun el pais/cuenta.
# MERCADO_PAGO_ACCESS_TOKEN=your-mercado-pago-test-access-token
# MERCADO_PAGO_PUBLIC_KEY=your-mercado-pago-test-public-key
